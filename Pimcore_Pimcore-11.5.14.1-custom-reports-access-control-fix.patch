+        if ($user instanceof UserProxy) {
+            $user = $user->getUser();
+        }
+
+        if (!($user->isAdmin() || $this->getShareGlobally() || $user->isAllowed('reports_config'))) {
+            $sharedUserIds = $this->getSharedUserIds();
